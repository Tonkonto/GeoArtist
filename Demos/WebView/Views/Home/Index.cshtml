@using GeoComponent.Contracts
@using System.Text.Json

@{
    ViewData["Title"] = "GeoArtist Demo";

    var sampleGeoJson = JsonSerializer.Serialize(new
    {
        type = "FeatureCollection",
        features = new[]
        {
            new
            {
                type = "Feature",
                properties = new { name = "Sample polygon" },
                geometry = new
                {
                    type = "Polygon",
                    coordinates = new[]
                    {
                        new[]
                        {
                            new[] { 74.60, 42.87 },
                            new[] { 74.61, 42.87 },
                            new[] { 74.61, 42.88 },
                            new[] { 74.60, 42.88 },
                            new[] { 74.60, 42.87 }
                        }
                    }
                }
            }
        }
    });

    var mapOptions = new GeoMapOptions
    {
        MapId = "demo-map",
        Height = "420px",
        InitialLat = 42.87,
        InitialLng = 74.60,
        InitialZoom = 12,
        FitBounds = true
    };

    var editorMapOptions = new GeoMapOptions
    {
        MapId = "demo-editor",
        Height = "420px",
        InitialLat = 42.87,
        InitialLng = 74.60,
        InitialZoom = 12,
        FitBounds = true
    };

    var editorOptions = new GeoEditorOptions
    {
        Enabled = true,
        AllowPolygon = true,
        AllowRectangle = true,
        AllowPolyline = true,
        AllowMarker = true,
        AllowEdit = true,
        AllowDelete = true,
        AllowTextInputSync = true,
        AutoApplyTextChanges = true
    };

    var mapOptionsJson = JsonSerializer.Serialize(new
    {
        mapId = mapOptions.MapId,
        height = mapOptions.Height,
        initialLat = mapOptions.InitialLat,
        initialLng = mapOptions.InitialLng,
        initialZoom = mapOptions.InitialZoom,
        fitBounds = mapOptions.FitBounds,
        polygonColor = mapOptions.PolygonColor,
        polygonOpacity = mapOptions.PolygonOpacity,
        showTileLayer = mapOptions.ShowTileLayer,
        tileLayerUrl = mapOptions.TileLayerUrl,
        tileLayerAttribution = mapOptions.TileLayerAttribution
    });
}

<h2 class="mb-3">GeoArtist Demo</h2>
<p class="text-muted">Карта и редактор рендерятся из GeoComponent. WebView выступает только как demo-host.</p>

<div class="d-flex gap-2 flex-wrap mb-3">
    <button class="btn btn-sm btn-primary" type="button" onclick="renderFromController()">GET /Home/TestPolygon</button>
    <button class="btn btn-sm btn-outline-primary" type="button" onclick="postGeoJsonSingle()">POST /api/geo/geojson</button>
    <button class="btn btn-sm btn-outline-primary" type="button" onclick="postGeoJsonBatch()">POST /api/geo/geojson/batch</button>
    <button class="btn btn-sm btn-outline-secondary" type="button" onclick="postWktSingle()">POST /api/geo/wkt</button>
    <button class="btn btn-sm btn-outline-secondary" type="button" onclick="postWktBatch()">POST /api/geo/wkt/batch</button>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <h5>Request</h5>
        <pre id="requestBox" class="border rounded p-2 bg-light" style="min-height:220px"></pre>
    </div>
    <div class="col-lg-6">
        <h5>Response</h5>
        <pre id="responseBox" class="border rounded p-2 bg-light" style="min-height:220px"></pre>
    </div>
</div>

<div class="row g-3">
    <div class="col-xl-6">
        <h4>Map Mode</h4>
        <geo-map geo-json="@sampleGeoJson" map-options="@mapOptions" include-assets="false"></geo-map>
    </div>

    <div class="col-xl-6">
        <h4>Editor Mode</h4>
        <geo-map geo-json="@sampleGeoJson" map-options="@editorMapOptions" editor-options="@editorOptions" mode="editor" include-assets="true"></geo-map>
    </div>
</div>

@section Scripts {
<script>
const mapOptions = @Html.Raw(mapOptionsJson);

function setRequest(url, payload) {
    const box = document.getElementById("requestBox");
    box.textContent = `${url}\n\n${JSON.stringify(payload, null, 2)}`;
}

function setResponse(data) {
    const box = document.getElementById("responseBox");
    box.textContent = typeof data === "string" ? data : JSON.stringify(data, null, 2);
}

async function requestJson(url, payload) {
    setRequest(url, payload);

    const response = await fetch(url, {
        method: payload ? "POST" : "GET",
        headers: payload ? { "Content-Type": "application/json" } : undefined,
        body: payload ? JSON.stringify(payload) : undefined
    });

    const text = await response.text();
    let data;

    try {
        data = text ? JSON.parse(text) : null;
    } catch {
        data = text;
    }

    setResponse(data);

    if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
    }

    return data;
}

function renderApiResultToMap(data) {
    const items = Array.isArray(data) ? data : [data];
    const geoItems = items
        .filter(x => x && x.geoJson)
        .map(x => {
            try {
                return JSON.parse(x.geoJson);
            } catch {
                return null;
            }
        })
        .filter(Boolean);

    window.GeoArtist.renderMapFromPayload({
        mode: "map",
        mapOptions,
        geoJson: {
            type: "FeatureCollection",
            features: geoItems.flatMap(item => item?.features ?? [])
        }
    });
}

async function renderFromController() {
    const data = await requestJson("/Home/TestPolygon", null);

    window.GeoArtist.renderMapFromPayload({
        mode: "map",
        mapOptions,
        geoJson: data
    });
}

async function postGeoJsonSingle() {
    const payload = {
        geoJson: JSON.stringify({
            type: "Polygon",
            coordinates: [[
                [74.60, 42.87],
                [74.62, 42.87],
                [74.62, 42.89],
                [74.60, 42.89],
                [74.60, 42.87]
            ]]
        })
    };

    const data = await requestJson("/api/geo/geojson", payload);
    renderApiResultToMap(data);
}

async function postGeoJsonBatch() {
    const payload = {
        geoJsonList: [
            JSON.stringify({
                type: "Polygon",
                coordinates: [[
                    [74.60, 42.87],
                    [74.61, 42.87],
                    [74.61, 42.88],
                    [74.60, 42.88],
                    [74.60, 42.87]
                ]]
            }),
            JSON.stringify({
                type: "Polygon",
                coordinates: [[
                    [74.62, 42.87],
                    [74.63, 42.87],
                    [74.63, 42.88],
                    [74.62, 42.88],
                    [74.62, 42.87]
                ]]
            })
        ]
    };

    const data = await requestJson("/api/geo/geojson/batch", payload);
    renderApiResultToMap(data);
}

async function postWktSingle() {
    const payload = {
        wkt: "POLYGON((74.60 42.87,74.62 42.87,74.62 42.89,74.60 42.89,74.60 42.87))",
        srid: 4326
    };

    const data = await requestJson("/api/geo/wkt", payload);
    renderApiResultToMap(data);
}

async function postWktBatch() {
    const payload = {
        wktList: [
            "POLYGON((74.60 42.87,74.61 42.87,74.61 42.88,74.60 42.88,74.60 42.87))",
            "POLYGON((74.62 42.87,74.63 42.87,74.63 42.88,74.62 42.88,74.62 42.87))"
        ],
        srid: 4326
    };

    const data = await requestJson("/api/geo/wkt/batch", payload);
    renderApiResultToMap(data);
}
</script>
}
