@model WebView.Models.Home.HomeMapDemoViewModel

@{
    ViewData["Title"] = "GeoArtist Demo";
}

<h2 class="mb-3">GeoArtist Demo</h2>

<div class="d-flex gap-2 flex-wrap mb-3 js-map-demo-bar">
    <button type="button" class="btn btn-sm btn-outline-primary" data-src="@Url.Action("TestPolygon", "Home")">GET  /Home/TestPolygon</button>
    <button type="button" class="btn btn-sm btn-outline-primary" data-src="@Url.Action("DemoGeoJsonSingle", "Home")">POST /api/geo/geojson</button>
    <button type="button" class="btn btn-sm btn-outline-primary" data-src="@Url.Action("DemoGeoJsonBatch", "Home")">POST /api/geo/geojson/batch</button>
    <button type="button" class="btn btn-sm btn-outline-info" data-src="@Url.Action("DemoWktSingle", "Home")">POST /api/geo/wkt</button>
    <button type="button" class="btn btn-sm btn-outline-info" data-src="@Url.Action("DemoWktBatch", "Home")">POST /api/geo/wkt/batch</button>
</div>

@{
    var mapOptions = new GeoArtist.Contracts.GeoMapOptions
    {
        MapId = "demo-map",
        Height = "420px",
        PolygonColor = "#2563eb",
        PolygonOpacity = 0.45
    };

    var editorMapOptions = new GeoArtist.Contracts.GeoMapOptions
    {
        MapId = "demo-editor",
        Height = "420px",
        PolygonColor = "#0f766e",
        PolygonOpacity = 0.45
    };
    var editorOptions = new GeoArtist.Contracts.GeoEditorOptions
    {
        SnapSensitivity = 10,
        NodeSize = 10,
        DrawColor = "#e11d48",
        DragClickTolerance = 10,
        UiScale = 0.85,
        ActionsScale = 0.9,
        TooltipScale = 0.8,
        AllowCircleMarker = true,
        AllowText = true,
        AllowCut = true,
        AllowRotate = true,
        UseGeoJsonTextArea = true
    };
}

<div class="row g-3">
    <div class="col-xl-6">
        <h4>Map Mode</h4>
        <geo-map geo-json="@Model.GeoJson" map-options="@mapOptions" include-assets="false" />
    </div>

    <div class="col-xl-6">
        <h4>Editor Mode</h4>
        <geo-map geo-json="@Model.GeoJson" map-options="@editorMapOptions" editor-options="@editorOptions" mode="editor" include-assets="true" />
    </div>
</div>

@section Scripts {
<script>
// fetch executable JS from Home/* actions; server body is literally `window.GeoArtist.updateGeoJson({...});`
document.querySelector(".js-map-demo-bar")?.addEventListener("click", function (e) {
    var b = e.target.closest("button[data-src]");
    if (!b) return;
    fetch(b.dataset.src).then(function (r) { return r.text(); }).then(eval);
});
</script>
}
